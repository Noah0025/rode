# 复制为 .env 填真实值（.env 已 gitignore，勿提交）
# RODE_GLASSES_TOKEN 必填！见 SETUP step 2：openssl rand -hex 24 生成后写入 .env。
# 这里故意注释掉占位符——否则 cp 后再 echo 追加真值会得到两条 RODE_GLASSES_TOKEN，
# loader 取第一条(=占位符)→认证必坏。注释行不会被 loader 读取，cp+追加即可。
# RODE_GLASSES_TOKEN=
PORT=18790
# ↑ 端口被占用就改这里（如 18795），其余不用动
RODE_STT_ENGINE=whisperserver
RODE_WHISPER_MODEL=models/ggml-medium.bin
RODE_WHISPER_LANG=auto
# 可选
# RODE_RATE_MAX=30
# RODE_BODY_LIMIT=26214400
# RODE_STATE_DIR=.
